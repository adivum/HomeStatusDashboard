@using System.Reflection
@typeparam TItem

<div class="table-responsive">
    <table class="table table-hover align-middle">
        <thead class="table-light">
            <tr>
                @foreach (var column in Columns)
                {
                    <th @onclick="() => SortBy(column.PropertyName)" 
                        style="cursor: pointer; user-select: none;"
                        title="Click to sort"
                        class="fw-bold text-dark">
                        <span class="d-flex align-items-center gap-2">
                            @column.Title
                            @if (SortColumn == column.PropertyName)
                            {
                                <i class="bi @(SortAscending ? "bi-sort-up" : "bi-sort-down")" style="font-size: 0.9rem;"></i>
                            }
                        </span>
                    </th>
                }
            </tr>
        </thead>
        <tbody>
            @foreach (var item in PaginatedItems)
            {
                <tr @onclick="() => OnRowClick(item)" class="table-row-clickable" style="cursor: pointer;">
                    @foreach (var column in Columns)
                    {
                        <td>
                            @if (column.Template != null)
                            {
                                @column.Template(item)
                            }
                            else
                            {
                                @GetPropertyValue(item, column.PropertyName)?.ToString()
                            }
                        </td>
                    }
                </tr>
            }
        </tbody>
    </table>
</div>

@if (TotalPages > 1)
{
    <nav aria-label="Page navigation" class="d-flex justify-content-between align-items-center mt-4">
        <div class="text-muted small">
            Page <strong>@CurrentPage</strong> of <strong>@TotalPages</strong> (total <strong>@Items.Count()</strong> items)
        </div>
        <ul class="pagination mb-0">
            <li class="page-item @(CurrentPage == 1 ? "disabled" : "")">
                <button class="page-link" @onclick="() => CurrentPage = 1" title="First page">
                    <i class="bi bi-chevron-double-left"></i>
                </button>
            </li>
            <li class="page-item @(CurrentPage == 1 ? "disabled" : "")">
                <button class="page-link" @onclick="() => CurrentPage--" title="Previous page">
                    <i class="bi bi-chevron-left"></i>
                </button>
            </li>

            @for (int i = Math.Max(1, CurrentPage - 2); i <= Math.Min(TotalPages, CurrentPage + 2); i++)
            {
                var pageNum = i;
                <li class="page-item @(CurrentPage == pageNum ? "active" : "")">
                    <button class="page-link" @onclick="() => CurrentPage = pageNum">@pageNum</button>
                </li>
            }

            <li class="page-item @(CurrentPage == TotalPages ? "disabled" : "")">
                <button class="page-link" @onclick="() => CurrentPage++" title="Next page">
                    <i class="bi bi-chevron-right"></i>
                </button>
            </li>
            <li class="page-item @(CurrentPage == TotalPages ? "disabled" : "")">
                <button class="page-link" @onclick="() => CurrentPage = TotalPages" title="Last page">
                    <i class="bi bi-chevron-double-right"></i>
                </button>
            </li>
        </ul>
    </nav>
}

@code {
    [Parameter]
    public IEnumerable<TItem> Items { get; set; } = [];

    [Parameter]
    public List<DataTableColumn<TItem>> Columns { get; set; } = [];

    [Parameter]
    public int PageSize { get; set; } = 25;

    [Parameter]
    public string SortColumn { get; set; } = string.Empty;

    [Parameter]
    public bool SortAscending { get; set; } = true;

    [Parameter]
    public EventCallback<TItem> OnRowClicked { get; set; }

    private int CurrentPage = 1;

    private IEnumerable<TItem> SortedItems
    {
        get
        {
            if (string.IsNullOrEmpty(SortColumn))
                return Items;

            var property = typeof(TItem).GetProperty(SortColumn, BindingFlags.Public | BindingFlags.Instance | BindingFlags.IgnoreCase);
            if (property == null)
                return Items;

            var sorted = Items.AsEnumerable();
            sorted = SortAscending
                ? sorted.OrderBy(x => property.GetValue(x))
                : sorted.OrderByDescending(x => property.GetValue(x));

            return sorted;
        }
    }

    private int TotalPages => (int)Math.Ceiling((double)Items.Count() / PageSize);

    private IEnumerable<TItem> PaginatedItems
    {
        get
        {
            var skip = (CurrentPage - 1) * PageSize;
            return SortedItems.Skip(skip).Take(PageSize);
        }
    }

    private void SortBy(string propertyName)
    {
        if (SortColumn == propertyName)
        {
            SortAscending = !SortAscending;
        }
        else
        {
            SortColumn = propertyName;
            SortAscending = true;
        }
        CurrentPage = 1;
    }

    private object? GetPropertyValue(TItem item, string propertyName)
    {
        var property = typeof(TItem).GetProperty(propertyName, BindingFlags.Public | BindingFlags.Instance | BindingFlags.IgnoreCase);
        return property?.GetValue(item);
    }

    private async Task OnRowClick(TItem item)
    {
        await OnRowClicked.InvokeAsync(item);
    }
}

<style>
    .table-row-clickable:hover {
        background-color: #e7f1ff;
        transition: background-color 0.15s ease;
    }
</style>
