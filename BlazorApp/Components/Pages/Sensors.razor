@page "/sensors"
@using Core.Interfaces
@using Core.Models
@using BlazorApp.Components.Shared
@using Core.Models.EntityViews
@using Core.Services
@inject IHomeAssistantService HaService
@inject NavigationManager Navigation

@rendermode InteractiveServer

<PageTitle>Sensors</PageTitle>

<h1 class="mb-4">Sensors</h1>

<div class="mb-4">
    <div class="input-group">
        <span class="input-group-text"><i class="bi bi-search"></i></span>
        <input @bind="searchTerm"
               @bind:event="oninput"
               placeholder="Search entities..."
               class="form-control" />
    </div>
</div>

@if (isLoading)
{
    <p>Loading...</p>
}
else if (FilteredStates.Any())
{
    <DataTable Items="FilteredStates" Columns="tableColumns" PageSize="25" SortColumn="LastUpdated" SortAscending="false" OnRowClicked="@((IEntityView sensor) => HandleRowClickAsync(sensor))" />
}
else
{
    <p>No results for "<strong>@searchTerm</strong>".</p>
}

@code {
    private IEnumerable<IEntityView> allStates = [];
    private string searchTerm = string.Empty;
    private bool isLoading = true;
    private List<DataTableColumn<IEntityView>> tableColumns = [];

    private IEnumerable<IEntityView> FilteredStates => allStates
        .Where(s => string.IsNullOrWhiteSpace(searchTerm)
                    || s.EntityId.Contains(searchTerm, StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync()
    {
        tableColumns =
        [
            new DataTableColumn<IEntityView>("Entity ID", "EntityId"),
            new DataTableColumn<IEntityView>("State", "State"),
            new DataTableColumn<IEntityView>("Last Updated", "LastUpdated", 
                item => @<text>@item.LastUpdated.ToLocalTime().ToString("dd-MM-yyyy HH:mm:ss")</text>)
        ];
        
        try{
            var views = await HaService.GetEntitiesListViewsAsync();
            allStates = views.ToList();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading entities: {ex.Message}");
            allStates = [];
        }
        finally
        {
            isLoading = false;
        }
    }

    private void HandleRowClick(IEntityView sensor)
    {
        Navigation.NavigateTo($"/sensor/{Uri.EscapeDataString(sensor.EntityId)}");
    }

    private Task HandleRowClickAsync(IEntityView sensor)
    {
        HandleRowClick(sensor);
        return Task.CompletedTask;
    }
}